# ============================================================================
# CONFIGURACIÓN BACKEND - JAMCONNECT / ÓOLALE MOBILE
# ============================================================================
# Documento de configuración de variables de entorno para el backend
# Creado: 22/01/2026
# Versión: 1.0

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Alternativa para desarrollo local
SUPABASE_LOCAL_URL=http://localhost:54321
SUPABASE_LOCAL_ANON_KEY=YOUR_LOCAL_ANON_KEY

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/jamconnect_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# AUTHENTICATION
# ============================================================================
JWT_SECRET=YOUR_JWT_SECRET_KEY_MIN_32_CHARS
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Autenticación social (opcional)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# ============================================================================
# MERCADO PAGO CONFIGURATION
# ============================================================================
MERCADOPAGO_ACCESS_TOKEN=YOUR_MERCADO_PAGO_TOKEN
MERCADOPAGO_PUBLIC_KEY=YOUR_MERCADO_PAGO_PUBLIC_KEY
MERCADOPAGO_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_CANCEL_URL=http://localhost:3000/payment/cancel

# ============================================================================
# MEDIA STORAGE (AWS S3 o alternativa)
# ============================================================================
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=jamconnect-media
AWS_S3_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_S3_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_PUBLIC_URL=https://jamconnect-media.s3.amazonaws.com

# Alternativa: Supabase Storage
SUPABASE_STORAGE_BUCKET=portfolio-media
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=mp4,mov,avi,mp3,wav,flac,jpg,png,gif,webp

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@jamconnect.app
SENDGRID_FROM_NAME=JAMConnect

# Alternativa: SMTP genérico
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL@gmail.com
SMTP_PASSWORD=YOUR_EMAIL_PASSWORD
SMTP_FROM_NAME=JAMConnect Óolale

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_PORT=3001
API_HOST=localhost
NODE_ENV=development

# Rate limiting
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json

# Sentry (error tracking)
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
SENTRY_ENVIRONMENT=development
SENTRY_TRACE_SAMPLE_RATE=0.1

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_PORTFOLIO_FEATURES=true
ENABLE_RANKING_SYSTEM=true
ENABLE_PAYMENT_SYSTEM=true
ENABLE_REAL_TIME_NOTIFICATIONS=true
ENABLE_ANALYTICS=true

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600
SESSION_SECRET=YOUR_SESSION_SECRET_MIN_32_CHARS

# ============================================================================
# SECURITY
# ============================================================================
BCRYPT_ROUNDS=10
SESSION_SECURE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

# ============================================================================
# NOTIFICATIONS
# ============================================================================
ENABLE_PUSH_NOTIFICATIONS=true
FCM_PROJECT_ID=YOUR_FCM_PROJECT_ID
FCM_PRIVATE_KEY=YOUR_FCM_PRIVATE_KEY
FCM_CLIENT_EMAIL=YOUR_FCM_CLIENT_EMAIL

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
DEBUG_MODE=false
SEED_DATABASE=false
MOCK_PAYMENTS=false

# ============================================================================
# PRODUCTION OVERRIDES
# ============================================================================
# NODE_ENV=production
# LOG_LEVEL=warn
# SESSION_SECURE=true
# DEBUG_MODE=false
# MOCK_PAYMENTS=false
